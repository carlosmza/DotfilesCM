@import "../fonts/font-ln.rasi"
@import "../themes/theme-ln.rasi"

configuration {
    show-icons: true;
}

window {
    width: 350px;
    background-color: @bg;
    border-radius: 12px;
    padding: 20px;
}

listview {
    lines: 5;
    spacing: 10px;
}

element {
    padding: 12px;
    border-radius: 10px;
}

element selected {
    background-color: @accent;
    border: 2px;
    border-color: @accent;
}

element-icon {
    size: 32px;
}

element-text {
    horizontal-align: 0.5;
}
