@import "../fonts/font-ln.rasi"
@import "../themes/theme-ln.rasi"

configuration {
    show-icons: true;
}

window {
    width: 500px;
    background-color: @bg;
    border-radius: 14px;
    padding: 18px;
}

listview {
    lines: 6;
    spacing: 10px;
}

element {
    padding: 12px;
    border-radius: 12px;
    background-color: @bg-alt;
}

element selected {
    background-color: @accent;
}

element-icon {
    size: 36px;
}

element-text {
    margin: 0px 0px 0px 12px;
}
